        "order": 1,
        "disabled": false,
        "hidden": false
    },
    {
        "id": "v2_mqtt_broker",
        "type": "mqtt-broker",
        "name": "test.mosquitto.org",
        "broker": "test.mosquitto.org",
        "port": 1883,
        "clientid": "nodered_vitalmon",
        "autoConnect": true,
        "usetls": false,
        "protocol": "mqtt://",
        "keepalive": "60",
        "cleansession": true,
        "birthTopic": "",
        "birthQos": "0",
        "birthPayload": "",
        "closeTopic": "",
        "closeQos": "0",
        "closePayload": "",
        "willTopic": "",
        "willQos": "0",
        "willPayload": ""
    },
    {
        "id": "v2_mqtt_in_vitals",
        "type": "mqtt in",
        "name": "Vitals",
        "topic": "hospital/patient/001/vitals",
        "qos": "1",
        "datatype": "auto-detect",
        "broker": "v2_mqtt_broker",
        "x": 120,
        "y": 100,
        "wires": [["v2_json_vitals"]]
    },
    {
        "id": "v2_json_vitals",
        "type": "json",
        "name": "Parse JSON",
        "property": "payload",
        "action": "",
        "pretty": false,
        "x": 280,
        "y": 100,
        "wires": [["v2_split_vitals"]]
    },
    {
        "id": "v2_split_vitals",
        "type": "function",
        "name": "Split & Route",
        "func": "if (!msg.payload) return null;\n\nflow.set('spo2',      msg.payload.spo2);\nflow.set('heart_rate', msg.payload.heart_rate);\nflow.set('temperature', msg.payload.temperature);\nflow.set('status',    msg.payload.patient_status);\n\nreturn [\n    { payload: msg.payload.spo2 },\n    { payload: msg.payload.heart_rate },\n    { payload: msg.payload.temperature },\n    { payload: msg.payload.patient_status },\n    msg\n];",
        "outputs": 5,
        "noerr": 0,
        "x": 440,
        "y": 100,
        "wires": [
            ["v2_gauge_spo2"],
            ["v2_gauge_hr"],
            ["v2_gauge_temp"],
            ["v2_status_colorizer"],
            ["v2_chart_prep"]
        ]
    },
    {
        "id": "v2_gauge_spo2",
        "type": "ui_gauge",
        "name": "SpO2",
        "group": "v2_grp_status",
        "order": 2,
        "width": 2,
        "height": 4,
        "gtype": "gage",
        "title": "SpO2",
        "label": "%",
        "format": "{{value}}",
        "min": 80,
        "max": 100,
        "colors": ["#e74c3c", "#f39c12", "#2ecc71"],
        "seg1": 90,
        "seg2": 94,
        "x": 620,
        "y": 60,
        "wires": []
    },
    {
        "id": "v2_gauge_hr",
        "type": "ui_gauge",
        "name": "Heart Rate",
        "group": "v2_grp_status",
        "order": 3,
        "width": 2,
        "height": 4,
        "gtype": "gage",
        "title": "Heart Rate",
        "label": "bpm",
        "format": "{{value}}",
        "min": 30,
        "max": 160,
        "colors": ["#e74c3c", "#f39c12", "#2ecc71", "#f39c12", "#e74c3c"],
        "seg1": 50,
        "seg2": 60,
        "seg3": 100,
        "seg4": 120,
        "x": 620,
        "y": 120,
        "wires": []
    },
    {
        "id": "v2_gauge_temp",
        "type": "ui_gauge",
        "name": "Temperature",
        "group": "v2_grp_status",
        "order": 4,
        "width": 2,
        "height": 4,
        "gtype": "gage",
        "title": "Temperature",
        "label": "°C",
        "format": "{{value}}",
        "min": 35,
        "max": 41,
        "colors": ["#2ecc71", "#f39c12", "#e74c3c"],
        "seg1": 37.5,
        "seg2": 38.5,
        "x": 620,
        "y": 180,
        "wires": []
    },
    {
        "id": "v2_text_status",
        "type": "ui_text",
        "name": "Status",
        "group": "v2_grp_status",
        "order": 1,
        "width": 6,
        "height": 2,
        "label": "Patient Status",
        "format": "{{msg.payload}}",
        "layout": "row-center",
        "x": 620,
        "y": 240,
        "wires": []
    },
    {
        "id": "v2_chart_vitals",
        "type": "ui_chart",
        "name": "Vitals Timeline",
        "group": "v2_grp_status",
        "order": 5,
        "width": 6,
        "height": 6,
        "label": "Vitals",
        "chartType": "line",
        "legend": "true",
        "xformat": "HH:mm:ss",
        "interpolate": "linear",
        "nodata": "Waiting for data...",
        "ymin": "",
        "ymax": "",
        "removeOlder": "",
        "removeOlderPoints": "",
        "removeOlderUnit": "",
        "cutaxis": "cut",
        "colors": ["#3498db", "#e74c3c", "#2ecc71"],
        "useDifferentColor": true,
        "x": 620,
        "y": 300,
        "wires": []
    },
    {
        "id": "v2_chart_prep",
        "type": "function",
        "name": "Prepare Chart",
        "func": "var spo2 = flow.get('spo2') || 0;\nvar hr   = flow.get('heart_rate') || 0;\nvar temp = flow.get('temperature') || 0;\n\nif (spo2 === 0) return null;\n\nvar ts = Date.now();\n\nreturn [\n    { payload: [{ t: ts, y: spo2 }], topic: 'SpO2' },\n    { payload: [{ t: ts, y: hr   }], topic: 'Heart Rate' },\n    { payload: [{ t: ts, y: temp }], topic: 'Temperature' }\n];",
        "outputs": 3,
        "noerr": 0,
        "x": 440,
        "y": 300,
        "wires": [
            ["v2_chart_vitals"],
            ["v2_chart_vitals"],
            ["v2_chart_vitals"]
        ]
    },
    {
        "id": "v2_status_colorizer",
        "type": "function",
        "name": "Colorize Status",
        "func": "var color = '#2ecc71';\nif (msg.payload === 'Warning')  color = '#f39c12';\nif (msg.payload === 'Critical') color = '#e74c3c';\nmsg.payload = '<span style=\"font-size:24px;font-weight:bold;color:' + color + '\">' + msg.payload + '</span>';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 440,
        "y": 240,
        "wires": [["v2_text_status"]]
    },
    {
        "id": "v2_mqtt_in_state",
        "type": "mqtt in",
        "name": "State",
        "topic": "hospital/patient/001/state",
        "qos": "0",
        "datatype": "auto-detect",
        "broker": "v2_mqtt_broker",
        "x": 120,
        "y": 240,
        "wires": [["v2_status_colorizer"]]
    },
    {
        "id": "v2_mqtt_in_alarm",
        "type": "mqtt in",
        "name": "Alarm",
        "topic": "hospital/patient/001/alarm",
        "qos": "1",
        "datatype": "string",
        "broker": "v2_mqtt_broker",
        "x": 120,
        "y": 400,
        "wires": [["v2_json_alarm"]]
    },
    {
        "id": "v2_json_alarm",
        "type": "json",
        "name": "Parse Alarm",
        "property": "payload",
        "action": "",
        "pretty": false,
        "x": 280,
        "y": 400,
        "wires": [["v2_alarm_format"]]
    },
    {
        "id": "v2_alarm_format",
        "type": "function",
        "name": "Format Alarm",
        "func": "if (!msg.payload || typeof msg.payload !== 'object') return null;\nif (!msg.payload.alarm_status && !msg.payload.spo2) return null;\n\nvar alarm = msg.payload;\nvar ts = alarm.timestamp || new Date().toISOString();\nvar color = alarm.alarm_status === 'Critical' ? '#e74c3c' : '#f39c12';\n\nmsg.payload = {\n    alarm: alarm.alarm_status || 'Unknown',\n    spo2: alarm.spo2 || 0,\n    heart_rate: alarm.heart_rate || 0,\n    temperature: alarm.temperature || 0,\n    timestamp: ts\n};\n\nvar toastMsg = alarm.alarm_status + ' Alarm! SpO2:' + (alarm.spo2 || 0) + '% HR:' + (alarm.heart_rate || 0) + ' Temp:' + (alarm.temperature || 0) + '°C';\n\nreturn [\n    msg,\n    { payload: '🚨 ' + toastMsg }\n];",
        "outputs": 2,
        "noerr": 0,
        "x": 440,
        "y": 400,
        "wires": [
            ["v2_alarm_table"],
            ["v2_alarm_toast"]
        ]
    },
    {
        "id": "v2_alarm_table",
        "type": "ui_table",
        "name": "Alarm Log",
        "group": "v2_grp_alarms",
        "order": 1,
        "width": 6,
        "height": 8,
        "columns": [
            {"title": "Time",     "field": "timestamp",  "width": 25},
            {"title": "Alarm",    "field": "alarm",      "width": 20},
            {"title": "SpO2",    "field": "spo2",       "width": 15},
            {"title": "HR",      "field": "heart_rate",  "width": 15},
            {"title": "Temp",    "field": "temperature","width": 25}
        ],
        "outputs": 1,
        "cts": true,
        "x": 620,
        "y": 400,
        "wires": []
    },
    {
        "id": "v2_alarm_toast",
        "type": "ui_toast",
        "name": "Alarm Notification",
        "group": "v2_grp_alarms",
        "order": 2,
        "width": 0,
        "height": 0,
        "position": "top-right",
        "duration": "10000",
        "x": 620,
        "y": 460,
        "wires": []
    },
    {
        "id": "v2_mqtt_in_presence",
        "type": "mqtt in",
        "name": "Presence",
        "topic": "hospital/patient/001/presence",
        "qos": "1",
        "datatype": "auto-detect",
        "broker": "v2_mqtt_broker",
        "x": 120,
        "y": 560,
        "wires": [["v2_presence_colorizer"]]
    },
    {
        "id": "v2_presence_text",
        "type": "ui_text",
        "name": "Connection Status",
        "group": "v2_grp_alarms",
        "order": 3,
        "width": 6,
        "height": 2,
        "label": "Device Connection",
        "format": "{{msg.payload}}",
        "layout": "row-center",
        "x": 340,
        "y": 560,
        "wires": []
    },
    {
        "id": "v2_presence_colorizer",
        "type": "function",
        "name": "Colorize Presence",
        "func": "var prev = context.get('prev_presence');\nif (prev === msg.payload) return null;\ncontext.set('prev_presence', msg.payload);\nvar color = msg.payload === 'online' ? '#2ecc71' : '#e74c3c';\nmsg.payload = '<span style=\"font-size:18px;font-weight:bold;color:' + color + '\">' + msg.payload + '</span>';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 480,
        "y": 560,
        "wires": [["v2_presence_text"]]
    },
