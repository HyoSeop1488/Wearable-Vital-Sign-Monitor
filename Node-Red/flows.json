    {
        "id": "9f0bbc3c6217",
        "type": "function",
        "z": "a8a7fa4c4a35f970",
        "name": "Prepare Chart Data",
        "func": "var spo2 = flow.get('spo2') || 0;\nvar hr   = flow.get('heart_rate') || 0;\nvar temp = flow.get('temperature') || 0;\n\nif (spo2 === 0) return null;\n\nnode.send({ payload: spo2, topic: 'SpO2' });\nnode.send({ payload: hr, topic: 'Heart Rate' });\nnode.send({ payload: temp, topic: 'Temperature' });\n\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "x": 1050,
        "y": 220,
        "wires": [
            [
                "f4a9c35dc255"
            ]
        ]
    },
    {
        "id": "9aaf20c74ad4",
        "type": "function",
        "z": "a8a7fa4c4a35f970",
        "name": "Colorize Status",
        "func": "var color = '#2ecc71';\nif (msg.payload === 'Warning')  color = '#f39c12';\nif (msg.payload === 'Critical') color = '#e74c3c';\nmsg.payload = '<span style=\"font-size:24px; font-weight:bold; color:' + color + '\">' + msg.payload + '</span>';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 1040,
        "y": 180,
        "wires": [
            [
                "614f950783ac"
            ]
        ]
