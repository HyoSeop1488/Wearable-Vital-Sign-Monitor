    {
        "id": "d2fc6a12f069",
        "type": "function",
        "name": "Split & Route",
        "func": "if (!msg.payload) return null;\n\nflow.set('spo2',      msg.payload.spo2);\nflow.set('heart_rate', msg.payload.heart_rate);\nflow.set('temperature', msg.payload.temperature);\nflow.set('status',    msg.payload.patient_status);\n\nreturn [\n    { payload: msg.payload.spo2 },\n    { payload: msg.payload.heart_rate },\n    { payload: msg.payload.temperature },\n    { payload: msg.payload.patient_status },\n    msg\n];",
        "outputs": 5,
        "noerr": 0,
        "x": 440,
        "y": 100,
        "wires": [
