    {
        "id": "0151704e28a0",
        "type": "function",
        "name": "Format Alarm",
        "func": "if (!msg.payload || typeof msg.payload !== 'object') return null;\nif (!msg.payload.alarm_status && !msg.payload.spo2) return null;\n\nvar alarm = msg.payload;\nvar ts = alarm.timestamp || new Date().toISOString();\nvar color = alarm.alarm_status === 'Critical' ? '#e74c3c' : '#f39c12';\n\nmsg.payload = {\n    alarm: alarm.alarm_status || 'Unknown',\n    spo2: alarm.spo2 || 0,\n    heart_rate: alarm.heart_rate || 0,\n    temperature: alarm.temperature || 0,\n    timestamp: ts\n};\n\nvar toastMsg = alarm.alarm_status + ' Alarm! SpO2:' + (alarm.spo2 || 0) + '% HR:' + (alarm.heart_rate || 0) + ' Temp:' + (alarm.temperature || 0) + '\u00b0C';\n\nreturn [\n    msg,\n    { payload: '\ud83d\udea8 ' + toastMsg }\n];",
        "outputs": 2,
        "noerr": 0,
        "x": 440,
        "y": 400,
        "wires": [
            [
                "6540d36efa89"
            ],
            [
                "3d107d2dd4de"
            ]
        ]
