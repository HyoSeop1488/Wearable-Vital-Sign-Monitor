    {
        "id": "d8b99af189fa",
        "type": "function",
        "z": "a8a7fa4c4a35f970",
        "name": "Format Alarm",
        "func": "if (!msg.payload || typeof msg.payload !== 'object' || !msg.payload.alarm_status) return null;\n\nvar alarm = msg.payload;\n\nvar ts = new Date().toLocaleTimeString('id-ID');\n\nvar tableMsg = {\n    payload: {\n        command: \"addRow\",\n        arguments: [\n            { alarm: alarm.alarm_status, spo2: alarm.spo2, heart_rate: alarm.heart_rate, temperature: alarm.temperature, timestamp: ts },\n            true\n        ]\n    }\n};\n\nvar alarmColor = '#2ecc71';\nvar alarmText = '\\u2713 Normal | SpO2: ' + alarm.spo2 + '% HR: ' + alarm.heart_rate + ' Temp: ' + alarm.temperature + '\\u00B0C';\n\nif (alarm.alarm_status === 'Critical') {\n    alarmColor = '#e74c3c';\n    alarmText = '\\uD83D\\uDEA8 ' + alarm.alarm_status + ' Alarm! SpO2: ' + alarm.spo2 + '% HR: ' + alarm.heart_rate + ' Temp: ' + alarm.temperature + '\\u00B0C';\n} else if (alarm.alarm_status === 'Warning') {\n    alarmColor = '#f39c12';\n    alarmText = '\\u26A0\\uFE0F ' + alarm.alarm_status + ' Alarm! SpO2: ' + alarm.spo2 + '% HR: ' + alarm.heart_rate + ' Temp: ' + alarm.temperature + '\\u00B0C';\n}\n\nvar alarmBarMsg = {\n    payload: {\n        text: alarmText,\n        color: alarmColor\n    }\n};\n\nreturn [tableMsg, alarmBarMsg];",
        "outputs": 2,
        "noerr": 0,
        "x": 1040,
        "y": 280,
        "wires": [
            [
                "2c84c7401444"
            ],
            [
                "98482e12398f"
            ]
        ]
    },
